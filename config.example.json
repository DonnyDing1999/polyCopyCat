{
  "mode": "paper",
  "ledger_path": "data/copycat.sqlite3",
  "targets": [
    {
      "address": "0x0000000000000000000000000000000000000001",
      "ratio": 0.1,
      "max_per_trade_usdc": 50,
      "paused": false
